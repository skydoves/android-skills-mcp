{
  "name": "android-skills-mcp",
  "version": "0.1.1",
  "description": "MCP server exposing android/skills to any MCP-capable client",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "android-skills-mcp": "./dist/bin.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup && node ../../scripts/build-skills-index.mjs --out ./dist/skills.json && chmod +x dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@android-skills/core": "workspace:*",
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Jaewoong Eum",
    "email": "skydoves2@gmail.com",
    "url": "https://github.com/skydoves"
  },
  "homepage": "https://github.com/skydoves/android-skills-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skydoves/android-skills-mcp.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/skydoves/android-skills-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "android",
    "android-skills",
    "agent-skills",
    "claude",
    "claude-code",
    "cursor",
    "ai",
    "jetpack-compose"
  ]
}
